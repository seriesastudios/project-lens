#!/bin/bash
# Launch Project Lens as a detached desktop app: opens a native window and
# returns your shell prompt immediately. The app survives closing this terminal.
# Closing the app window stops the server (one process — nothing orphaned).
# LM Studio must be running separately for chat to work.
#
# Stop from the CLI:  pkill -f app.desktop   (or kill the printed PID)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

LOG="$SCRIPT_DIR/.lens.log"
nohup "$SCRIPT_DIR/venv/bin/python" -m app.desktop >"$LOG" 2>&1 &
disown

echo "Project Lens started (pid $!)."
echo "Logs: $LOG"
